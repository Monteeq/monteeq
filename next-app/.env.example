# Server-only: FastAPI origin (no /api/v1 suffix). Used by Server Components.
# Mirrors VITE_API_URL from the Vite frontend.
API_BASE_URL=http://localhost:8000

# Client-accessible: same backend origin for HLS stream URLs and any
# browser-side fetch/WebSocket that cannot go through the server.
# Required because hls.js requests /videos/:id/stream/* from the browser.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Client-accessible: WebSocket host for chat (STEP 4). Leave empty to use
# the current page host. Mirrors VITE_WS_HOST.
NEXT_PUBLIC_WS_HOST=

# Public site origin for canonical URLs / Open Graph (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://monteeq.com

# Google OAuth Web Client ID (mirrors VITE_GOOGLE_CLIENT_ID). Required for
# GoogleLogin on /login and /signup.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
